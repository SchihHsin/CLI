  --acc:#834DF0; --acc2:#6B38D4; --acc-l:#A87FF5;
  --acc-dim:rgba(131,77,240,.08); --acc-b:rgba(131,77,240,.22);
  --bg:#F7F7FA; --bg2:#EEEEF3; --sur:#FFFFFF;
